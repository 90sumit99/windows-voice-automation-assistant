{
  "name": "zyrex",
  "version": "1.0.0",
  "description": "ZYREX - AI Windows Assistant",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run api\" \"wait-on http://localhost:5000 && electron .\"",
    "build": "electron-builder",
    "api": "echo API started separately"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "concurrently": "^8.2.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.zyrex.app",
    "productName": "ZYREX",
    "win": {
      "target": "nsis"
    }
  }
}
